package view

import "github.com/encador/trady/internal/templ/component"

templ Basic(content templ.Component) {
	<!DOCTYPE html>
	<html>
		<head>
			@component.Hello("pink")
		</head>
		<body class={ body } style="margin: 0px">
			@content
			@component.Hello("red")
			@component.Button("Click Me")
		</body>
	</html>
}

css body() {
	margin: 0px;
	display: flex;
	flex-direction: column;
	align-items: center;
	justify-content: center;
}
