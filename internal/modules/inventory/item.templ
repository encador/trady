package inventory

import "github.com/encador/trady/internal/models"

templ ItemList(items []models.Item) {
	<div id="item-list">
		for _, item := range items {
			@Item(item)
		}
	</div>
	<style>
		#item-list {
			display: flex;
			flex-wrap: wrap;
			padding: 15px;
			/* align-items: center; */
			justify-content: center;
			box-sizing: border-box;
			margin: 0;
			/* width: 100%; */
			/* height: 100%; */
			max-width: 100%;
			max-height: 100%;
			min-width: auto;
			min-height: auto;

			overflow: auto;
		}
	</style>
}

templ Item(item models.Item) {
	<div class="inventory-item">
		<div class="info">
			<img src={ item.ImageURL } alt="Item Image"/>
			<p class="name">{ item.Title }</p>
		</div>
	</div>
	<style>
		.inventory-item .name {
			overflow: hidden;
			height: 20px;
			font-weight: bold;
			width: 100%;
		}

		.inventory-item .info {
			border: 3px solid var(--dark-5);
			color: var(--white-3);
			border-radius: 10px;
			width: 120px;
			height: 130px;
			/* padding: 5px; */
			overflow: hidden;
		}

		.inventory-item .info:hover {
			cursor: pointer;
			border: 3px solid var(--blue-3);
			background: var(--blue-2);
		}

		.inventory-item {
			display: flex;
			flex-direction: column;
			align-items: center;
			justify-content: center;
			margin: 10px;
			/* border: 2px solid var(--dark-3); */
			background: var(--dark-1);
			border-radius: 10px;
			/* padding: 10px; */
			text-align: center;
			width: auto;
			height: auto;
			user-select: none;
		}
		.inventory-item img {
			width: 100%;
			height: 100px;
			object-fit: cover;
			border-bottom: 3px solid var(--dark-5);
			background: none;
		}
	</style>
}
